# infra/.env.example — copy to infra/.env and fill in real values for local dev.
#
# infra/.env is gitignored (repo root .gitignore has a blanket `.env` rule) —
# never commit it. This file documents every var docker-compose.yml consumes.
#
# OPENROUTER_API_KEY is NOT set here. It lives in backend/.env (also gitignored)
# and is loaded into the `backend`/`worker` containers via `env_file` in
# docker-compose.yml. See infra/architecture.md for the full contract.

# --- Postgres ---
POSTGRES_USER=textery
POSTGRES_PASSWORD=change-me
POSTGRES_DB=textery
# Host-side port only; the container always listens on 5432 internally.
POSTGRES_PORT=5432

# --- Redis ---
# Host-side port only; the container always listens on 6379 internally.
REDIS_PORT=6379

# --- Backend / Worker (arq) ---
# Host-side port for the backend API; the container always listens on 8000 internally.
BACKEND_PORT=8000
# DATABASE_URL and REDIS_URL are NOT set here — docker-compose.yml composes them
# from the vars above plus the in-network service DNS names (postgres, redis),
# e.g. postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
# and redis://redis:6379/0. That composition only works inside compose's own
# ${...} interpolation, not inside a plain .env file, so it lives in the compose
# file's `environment:` blocks instead.

# --- Frontend ---
# Host-side port; the container always listens on 80 internally.
FRONTEND_PORT=80
