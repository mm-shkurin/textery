# Build context for infra/docker/*.Dockerfile is the repo root (see
# infra/docker-compose.yml build.context: ..). Keep VCS/harness bookkeeping,
# language caches, and local envs out of build images.
.git
.claude
ProductSpecification
infra/.memory-bank
infra/swarm-report
node_modules
# Local Vite build output — the frontend image runs its own `npm run build` inside the
# Dockerfile, so shipping the host's dist/ only bloats the context (and trips buildkit's
# "invalid file request" on OneDrive-synced artifacts).
frontend/dist
.venv
__pycache__
*.pyc
.pytest_cache
.mypy_cache
.ruff_cache
htmlcov
coverage.xml
*.egg-info
.env
