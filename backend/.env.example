# backend/.env.example — copy to backend/.env and fill in real values for local dev.
#
# backend/.env is gitignored (repo root .gitignore has a blanket `.env` rule) —
# never commit it. This file documents every var the backend/worker containers
# consume, wired in via `env_file` in infra/docker-compose.yml. See
# infra/architecture.md for the full container-wiring contract.

# --- OpenRouter (text generation) ---
# See ProductSpecification/stories/01-auto-generate-doklad/interview.md for the
# decision to use OpenRouter (not the native Anthropic API) — one OpenAI-compatible
# gateway to Claude + other models, so story #6's model switching is a config
# change, not a new adapter.
OPENROUTER_API_KEY=change-me
# Specific model string is still an open item (see interview.md) — placeholder
# below, swap without a code change once decided.
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# --- Database / Cache ---
# DATABASE_URL and REDIS_URL are NOT set here — infra/docker-compose.yml composes
# them from infra/.env's Postgres/Redis vars plus in-network service DNS names
# (postgres, redis). Only backend-owned secrets belong in this file.
