# backend/.env.example — copy to backend/.env and fill in real values for local dev.
#
# backend/.env is gitignored (repo root .gitignore has a blanket `.env` rule) —
# never commit it. This file documents every var the backend containers
# consume, wired in via `env_file` in infra/docker-compose.yml. See
# infra/architecture.md for the full container-wiring contract.

# --- Generation provider ---
# Defaults to "gigachat" (GigaChatProvider, needs GIGACHAT_CREDENTIALS below).
# Set to "fake" to run without real credentials (FakeProvider, canned content).
GENERATION_PROVIDER=gigachat
GIGACHAT_CREDENTIALS=change-me
# Overrides the bundled Russian trust-CA PEM (adapters/generation_provider/certs)
# if GigaChat's cert chain changes. Usually leave unset.
# GIGACHAT_CA_BUNDLE=/path/to/ca-bundle.pem

# --- Auth / JWT ---
# HS256 signing key for access and refresh tokens. REQUIRED — the app refuses to
# start without it, deliberately: a default here would ship a signing key that is
# public in the git history, making every token in production forgeable by anyone
# who read the repo. Must be at least 32 bytes (RFC 7518 §3.2 for HS256) — a
# shorter key is brute-forceable offline from one captured token, so the app
# refuses that too rather than running visibly-fine and quietly forgeable.
# Generate with: openssl rand -hex 32
# Rotating it invalidates every issued token (tokens are stateless, so there is
# no revocation list to clear) — every client must log in again.
JWT_SECRET=change-me

# --- Generation sweep ---
# How long a generation may sit in pending/in_progress before the periodic sweep
# treats it as stranded and re-runs it. Defaults to 10.
# GENERATION_STALE_AFTER_MINUTES=10

# --- Database ---
# DATABASE_URL is NOT set here — infra/docker-compose.yml composes it from
# infra/.env's Postgres vars plus the in-network service DNS name (postgres).
# Only backend-owned secrets belong in this file.
#
# No REDIS_URL: the backend reads no such variable and has no Redis client in
# requirements.txt. It was listed here, in the README, and installed by CI, all
# for a dependency that does not exist.
