# Base URL for the generation API. Leave empty to route through the Vite
# dev server's /api proxy (see vite.config.ts).
VITE_API_BASE_URL=

# Target the dev proxy forwards /api requests to.
#
# SET THIS from BACKEND_PORT in your own infra/.env — it is per-repo-instance (parallel checkouts
# publish the backend on different host ports), so no number written here is right for everyone.
# Check it rather than copying: `grep BACKEND_PORT ../infra/.env`.
#
# This line previously said 8000, which is worse than merely stale: another service occupies 8000
# on this host, so copying the example verbatim did not fail with a connection error — it got
# someone else's app answering. Any wrong port here is a confusing bug; that one is a silent one.
VITE_API_PROXY_TARGET=http://127.0.0.1:8001

# Port the dev server listens on.
FRONTEND_PORT=5173
