# Base URL for the generation API. Leave empty to route through the Vite
# dev server's /api proxy (see vite.config.ts).
VITE_API_BASE_URL=

# Target the dev proxy forwards /api requests to.
#
# Set from BACKEND_PORT in your own infra/.env — parallel checkouts publish the backend on
# different host ports, so no number here is right for everyone. Check, don't copy:
#   grep BACKEND_PORT ../infra/.env
# Never 8000: another service holds that port on this host, so a wrong value there proxies to
# someone else's app instead of failing.
VITE_API_PROXY_TARGET=http://127.0.0.1:8001

# Port the dev server listens on.
FRONTEND_PORT=5173
