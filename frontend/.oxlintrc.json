{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react", "typescript", "oxc", "jsx-a11y"],
  "rules": {
    "react/rules-of-hooks": "error",
    "react/exhaustive-deps": "warn",
    "react/only-export-components": ["warn", { "allowConstantExport": true }],
    "no-unused-vars": "error",
    // console.log/debug/info are debugging leftovers and stay banned. error/warn are not: this
    // app has no reporting sink, so they are the only diagnostics a failed save or a dropped
    // request leaves behind, and a blanket ban would delete the trace rather than route it
    // somewhere better. Revisit if a real sink is ever wired up.
    "no-console": ["error", { "allow": ["error", "warn"] }],
    // Tokens live in sessionStorage, which any script on the origin can read. The reason that is
    // survivable is that nothing here injects unescaped markup — React escaping by default is a
    // property of the code, not a guarantee of the framework, and one dangerouslySetInnerHTML on
    // a server-supplied string would turn a stored XSS into a session handover. Banned so the
    // claim stays checkable rather than a comment someone has to remember.
    "react/no-danger": "error",
    "jsx-a11y/alt-text": "error",
    "jsx-a11y/anchor-is-valid": "error"
  },
  "overrides": [
    {
      // Build-time CLI scripts, not shipped code. `console` is their entire output channel — the
      // app-code ban exists because a stray log there reaches a user's devtools with nobody
      // reading it, which is not the situation here.
      "files": ["scripts/**"],
      "rules": {
        "no-console": "off"
      }
    }
  ]
}
